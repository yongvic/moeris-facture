// Résidence Moeris — Schéma v1.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// AUTHENTIFICATION & UTILISATEURS
// ============================================
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nom       String
  prenom    String
  role      Role     @default(STAFF)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  ADMIN
  STAFF
  MANAGER
}

// ============================================
// CLIENTS (CRM)
// ============================================
model Client {
  id            String         @id @default(cuid())
  prenom        String
  nom           String?
  email         String?        @unique
  telephone     String?
  dateNaissance DateTime?
  nationalite   String?
  numeroPiece   String?
  adresse       String?
  notes         String?
  segment       SegmentClient  @default(STANDARD)
  actif         Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  factures      Facture[]
  reservations  Reservation[]

  @@index([email])
  @@index([telephone])
  @@index([segment])
  @@map("clients")
}

enum SegmentClient {
  STANDARD
  FREQUENT
  VIP
  PREMIUM
}

// ============================================
// CHAMBRES
// ============================================
model Chambre {
  id          String        @id @default(cuid())
  numero      String        @unique
  nom         String?
  type        TypeChambre
  capacite    Int
  prixNuit    Decimal       @db.Decimal(10, 2)
  description String?
  equipements String[]
  statut      StatutChambre @default(DISPONIBLE)
  etage       Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  reservations Reservation[]

  @@map("chambres")
}

enum TypeChambre {
  STANDARD
  SUPERIEURE
  SUITE
  BUNGALOW
  VILLA
  DUPLEX
}

enum StatutChambre {
  DISPONIBLE
  OCCUPEE
  MAINTENANCE
  HORS_SERVICE
}

// ============================================
// RÉSERVATIONS
// ============================================
model Reservation {
  id            String             @id @default(cuid())
  clientId      String
  chambreId     String
  dateArrivee   DateTime
  dateDepart    DateTime
  nombreNuits   Int
  prixNegocie   Decimal?           @db.Decimal(10, 2)
  nombreAdultes Int                @default(1)
  nombreEnfants Int                @default(0)
  statut        StatutReservation  @default(CONFIRMEE)
  notes         String?
  checkInAt     DateTime?
  checkOutAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  client        Client             @relation(fields: [clientId], references: [id])
  chambre       Chambre            @relation(fields: [chambreId], references: [id])
  factures      Facture[]

  @@index([chambreId])
  @@index([dateArrivee, dateDepart])
  @@index([statut])
  @@map("reservations")
}

enum StatutReservation {
  CONFIRMEE
  CHECK_IN_EFFECTUE
  CHECK_OUT_EFFECTUE
  ANNULEE
  NO_SHOW
}

// ============================================
// FACTURES
// ============================================
model Facture {
  id             String         @id @default(cuid())
  numero         String         @unique
  clientId       String
  reservationId  String?
  evenementId    String?
  statut         StatutFacture  @default(OUVERTE)
  montantTotal   Decimal        @db.Decimal(10, 2) @default(0)
  montantPaye    Decimal        @db.Decimal(10, 2) @default(0)
  remiseGlobale  Decimal?       @db.Decimal(10, 2)
  remisePourcent Decimal?       @db.Decimal(5, 2)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  clotureeAt     DateTime?

  client         Client         @relation(fields: [clientId], references: [id])
  reservation    Reservation?   @relation(fields: [reservationId], references: [id])
  evenement      Evenement?     @relation(fields: [evenementId], references: [id])
  consommations  Consommation[]
  paiements      Paiement[]

  @@index([clientId])
  @@index([statut])
  @@index([createdAt])
  @@map("factures")
}

enum StatutFacture {
  OUVERTE
  PARTIELLEMENT_PAYEE
  PAYEE
  ANNULEE
}

// ============================================
// CONSOMMATIONS
// ============================================
model Consommation {
  id           String               @id @default(cuid())
  factureId    String
  categorie    CategorieConsommation
  description  String
  quantite     Decimal              @db.Decimal(10, 2) @default(1)
  prixUnitaire Decimal              @db.Decimal(10, 2)
  sousTotal    Decimal              @db.Decimal(10, 2)
  remise       Decimal?             @db.Decimal(10, 2)
  produitId    String?
  activiteId   String?
  supprimee    Boolean              @default(false)
  supprimeeAt  DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  facture      Facture              @relation(fields: [factureId], references: [id])
  produit      Produit?             @relation(fields: [produitId], references: [id])
  activite     Activite?            @relation(fields: [activiteId], references: [id])

  @@index([factureId])
  @@index([categorie])
  @@map("consommations")
}

enum CategorieConsommation {
  CHAMBRE
  RESTAURANT
  ACTIVITE
  EVENEMENT
  DIVERS
}

// ============================================
// PAIEMENTS
// ============================================
model Paiement {
  id          String      @id @default(cuid())
  factureId   String
  montant     Decimal     @db.Decimal(10, 2)
  modePaiement ModePaiement
  reference   String?
  note        String?
  encaisseePar String?
  createdAt   DateTime    @default(now())

  facture     Facture     @relation(fields: [factureId], references: [id])

  @@map("paiements")
}

enum ModePaiement {
  ESPECES
  VIREMENT
  MOBILE_MONEY
  CARTE_BANCAIRE
  CHEQUE
  AUTRE
}

// ============================================
// PRODUITS (RESTAURANT)
// ============================================
model Produit {
  id          String   @id @default(cuid())
  nom         String
  description String?
  prix        Decimal  @db.Decimal(10, 2)
  categorie   String
  disponible  Boolean  @default(true)
  archive     Boolean  @default(false)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  consommations Consommation[]

  @@map("produits")
}

// ============================================
// ACTIVITÉS
// ============================================
model Activite {
  id          String   @id @default(cuid())
  nom         String
  description String?
  prix        Decimal  @db.Decimal(10, 2)
  prixParUnite String   @default("personne")
  gratuit     Boolean  @default(false)
  capaciteMax Int?
  disponible  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  consommations Consommation[]

  @@map("activites")
}

// ============================================
// ÉVÉNEMENTS
// ============================================
model Evenement {
  id                 String             @id @default(cuid())
  titre              String
  type               TypeEvenement
  description        String?
  dateDebut          DateTime
  dateFin            DateTime
  capaciteMax        Int?
  prixParParticipant Decimal?           @db.Decimal(10, 2)
  prixForfait        Decimal?           @db.Decimal(10, 2)
  acompteRequis      Decimal?           @db.Decimal(10, 2)
  statut             StatutEvenement    @default(A_VENIR)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  participants       ParticipantEvenement[]
  factures           Facture[]

  @@map("evenements")
}

enum TypeEvenement {
  SOIREE
  SEMINAIRE
  MARIAGE
  ANNIVERSAIRE
  CONFERENCE
  AUTRE
}

enum StatutEvenement {
  A_VENIR
  EN_COURS
  TERMINE
  ANNULE
}

model ParticipantEvenement {
  id           String            @id @default(cuid())
  evenementId  String
  nom          String
  prenom       String
  contact      String?
  statut       StatutParticipant @default(INSCRIT)
  acomptePaye  Decimal?          @db.Decimal(10, 2)
  soldeRestant Decimal?          @db.Decimal(10, 2)
  createdAt    DateTime          @default(now())

  evenement    Evenement         @relation(fields: [evenementId], references: [id])

  @@map("participants_evenement")
}

enum StatutParticipant {
  INSCRIT
  PRESENT
  ABSENT
  ANNULE
}
